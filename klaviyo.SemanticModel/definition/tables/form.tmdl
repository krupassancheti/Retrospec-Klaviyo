	column 'Device Type' = ```
			
			IF(
			    OR(
			        form[Form Name] = "Evergreen Sitewide Popup Desktop", 
			        form[Form Name] = "Evergreen Sitewide Popup Desktop [RADIO CATEGORIES]"
			    ),
			    "Desktop Popup", 
			    IF(
			        OR(
			            form[Form Name] = "Evergreen Sitewide Popup Mobile", 
			            form[Form Name] = "Evergreen Sitewide Popup Mobile [RADIO CATEGORIES]"
			        ),
			        "Mobile Popup",
			        IF(
			            form[Form Name] = "20PercentoffAccessoriesPopUp | Vidi",
			            "20PercentoffAccessoriesPopUp | Vidi",
			            IF(
			                form[Form Name] = "20PercentoffAccessoriesPopUp | Mobile",
			                "20PercentoffAccessoriesPopUp | Mobile",
			                "Other"
			            )
			        )
			    )
			)
			
			```
		lineageTag: 0db7f84b-ba97-4ee9-b5ca-6f6d92e48452
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

