	column Date
		dataType: dateTime
		formatString: Long Date
		lineageTag: 481f855e-2931-43c6-8877-b8b2838624dc
		summarizeBy: none
		sourceColumn: Date

		variation Variation
			isDefault
			relationship: e84bd870-cb60-4a8a-9d33-e4bf0e4a86a7
			defaultHierarchy: LocalDateTable_3af523a0-13cd-4496-a74d-0837c329dc80.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition form = m
		mode: import
		source =
				let
				    Source = try GoogleSheets.Contents("https://docs.google.com/spreadsheets/d/1AzbAaYruKQjBDyz0kI8v_v6lqeHL7eVy6tnBqv8IhP0/edit?gid=0#gid=0") otherwise null,
				
				    Sheet1_Table =
				        if Source <> null then
				            try Source{[name="Sheet1",ItemKind="Sheet"]}[Data]
				            otherwise try Source{[name="Sheet1",ItemKind="Table"]}[Data]
				            otherwise #table({}, {})
				        else
				            #table({}, {}),
				
				    #"Promoted Headers" =
				        if Table.IsEmpty(Sheet1_Table) then
				            Sheet1_Table
				        else
				            Table.PromoteHeaders(Sheet1_Table, [PromoteAllScalars=true]),
				
				    #"Split Column by Position" =
				        if Table.HasColumns(#"Promoted Headers", "Date") then
				            Table.SplitColumn(#"Promoted Headers", "Date", Splitter.SplitTextByPositions({0, 10}, false), {"Date.1", "Date.2"})
				        else
				            #"Promoted Headers",
				
				    #"Removed Columns" =
				        if Table.HasColumns(#"Split Column by Position", "Date.2") then
				            Table.RemoveColumns(#"Split Column by Position",{"Date.2"})
				        else
				            #"Split Column by Position",
				
				    #"Changed Type" =
				        try Table.TransformColumnTypes(#"Removed Columns",
				            {{"Date.1", type date}, {"Form ID", type text}, {"Form Name", type text},
				             {"form_views", Int64.Type}, {"form_submissions", Int64.Type}})
				        otherwise #"Removed Columns",
				
				    #"Renamed Columns" =
				        try Table.RenameColumns(#"Changed Type",{{"Date.1", "Date"}})
				        otherwise #"Changed Type"
				
				in
				    #"Renamed Columns"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Exception

