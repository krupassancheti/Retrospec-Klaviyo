	measure 'dMOM Recipients Growth%' = ```
			
			VAR up_arrow = UNICHAR(129137) 
			VAR down_arrow = UNICHAR(129139) 
			VAR CurrentRecipients = [dRECIPIENTS] 
			VAR PPRecipients = [dPPRecipients]
			VAR Growth = DIVIDE(CurrentRecipients-PPRecipients,PPRecipients)
			RETURN 
			    IF(
			        Growth<0, ROUND(Growth*100,1)&"% "& down_arrow,
			        ROUND(Growth*100,1)&"% "& up_arrow
			    )
			```
		displayFolder: DRECP
		lineageTag: 03f578d3-76c5-44a8-92df-7434c418a2a3

	measure dPPRecipients = CALCULATE([dRECIPIENTS],DATESBETWEEN(DailyDimDate[Date],[dailystartofpreviousperiod],[dailyendofpreviousperiod]))
		formatString: 0
		displayFolder: DRECP
		lineageTag: 4288bc6e-26cd-47d2-b660-5088991804a9

	measure 'dColor PM Recipients' =
			
			VAR mom_growth = DIVIDE([dRECIPIENTS] - [dPPRecipients],[dPPRecipients])
			RETURN
			    IF(mom_growth<0, "red","green")
		displayFolder: DRECP
		lineageTag: c08517f6-1585-4ba3-9e9d-42de68d94481

	measure dPYRecipients = CALCULATE([dRECIPIENTS],DATEADD(DailyDimDate[Date],-1,YEAR))
