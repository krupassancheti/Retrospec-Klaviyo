	measure 'FUnqRecip 4WA' =
			var a = MAX(DailyDimDate[Start of Week])
			var b = a-28
			var c = b+27
			Return DIVIDE(CALCULATE(SUM('flow unique recipients'[unique_recipients]),FILTER(ALL(DailyDimDate),DailyDimDate[Date]>=b&&DailyDimDate[Date]<=c)),4)
		formatString: #,0
		displayFolder: Flow 4 WA
		lineageTag: 4bdeb6e5-2cd3-4cd4-a152-3311058c98d9

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'FUnqUnsubscribes 4WA' =
			var a = MAX(DailyDimDate[Start of Week])
			var b = a-28
			var c = b+27
			Return DIVIDE(CALCULATE(SUM('flow unique recipients'[unique_unsubscribers]),FILTER(ALL(DailyDimDate),DailyDimDate[Date]>=b&&DailyDimDate[Date]<=c)),4)
		formatString: #,0
		displayFolder: Flow 4 WA
		lineageTag: bb7bd063-be01-4620-b718-299e5e93d294

		annotation PBI_FormatHint = {"isDecimal":true}

