	measure 'CUnqRecip 4WA' =
			var a = MAX(CampaignDimDate[Start of Week])
			var b = a-28
			var c = b+27
			Return DIVIDE(CALCULATE(AVERAGE('campaign unique recipients'[unique_recipients]),FILTER(ALL(CampaignDimDate),CampaignDimDate[Send Date]>=b&&CampaignDimDate[Send Date]<=c)),4)
		formatString: #,0
		displayFolder: Campaign 4 WA
		lineageTag: 2564ac9f-ba87-45d7-abd9-4c46d2e643b1

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'FCurrent Week UnqRecipients' = CALCULATE([FlowUnqRecipients],FILTER(DailyDimDate,DailyDimDate[Current Week] = "Current Week"))
		formatString: #,0
		displayFolder: Flow Current Week
		lineageTag: 50318e23-16d8-42a6-bd53-6b53026786a7

	measure 'FCurrent Week UnqUnsubscribes' = CALCULATE([FlowUnqUnsubscribes],FILTER(DailyDimDate,DailyDimDate[Current Week] = "Current Week"))
		formatString: #,0
		displayFolder: Flow Current Week
		lineageTag: e9f7fcbd-4308-4363-aa02-ba8580f724e3

	measure 'FlowUnique Recip 4WA' = CALCULATE(AVERAGE('flow unique recipients'[unique_recipients]),FILTER(DailyDimDate,DailyDimDate[Date]>=TODAY()-28))
		formatString: #,0
		displayFolder: FLow 4 Week Average
		lineageTag: 2a7ff8fa-2bc9-4b20-bfcf-1f638706d4fe

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'FlowUnique Unsubscribes 4WA' = CALCULATE(AVERAGE('flow'[Unique Unsubscribes]),FILTER(DailyDimDate,DailyDimDate[Date]>=TODAY()-28))
		formatString: #,0
		displayFolder: FLow 4 Week Average
		lineageTag: 9bc22659-02f5-46d1-93dd-d63ce181fb35

		annotation PBI_FormatHint = {"isDecimal":true}

