	measure 'CCNFUnique Recip 4WA' =
			var a = MAX(CampaignDimDate[Start of Week])
			var b = a-28
			var c = b+27
			Return DIVIDE(CALCULATE([CCNF Unique Recipients],FILTER(ALL(CampaignDimDate),CampaignDimDate[Send Date]>=b&&CampaignDimDate[Send Date]<=c)),4)
		formatString: #,0
		displayFolder: CCNF 4 Week Average
		lineageTag: 675355e6-9c6a-48d7-94ea-aa5e43076f75

		annotation PBI_FormatHint = {"isDecimal":true}

