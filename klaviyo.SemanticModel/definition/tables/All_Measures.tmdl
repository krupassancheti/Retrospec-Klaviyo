	measure 'fYoY Recipients Change' = ```
			
			VAR up_arrow = UNICHAR(129137)
			VAR down_arrow = UNICHAR(129139)
			VAR CurrentRecipients = [FlowRecip]
			VAR PYRecipients = [fPYRecipients]
			VAR Growth = DIVIDE(CurrentRecipients - PYRecipients, PYRecipients)
			VAR Change = CurrentRecipients - PYRecipients
			RETURN
			    FORMAT(Change, "#,##0") & " (" &
