		lineageTag: b086a935-1aee-481f-9b9a-4518f4005cac

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure cPYDailyClickRate =
			
			VAR CurrentDates =
			    VALUES ( CampaignDimDate[Send Date] )
			
			VAR PYDates =
			    SELECTCOLUMNS (
			        CurrentDates,
			        "Send Date",
			        DATE (
			            YEAR ( [Send Date] ) - 1,
			            MONTH ( [Send Date] ),
			            DAY ( [Send Date] )
			        )
			    )
			RETURN
			CALCULATE (
			    [cCLICK TO RECIEVE RATE],
			    TREATAS ( PYDates, CampaignDimDate[Send Date] )
			)
			// CALCULATE([cCLICK TO RECIEVE RATE],DATEADD(CampaignDimDate[Send Date],-1,YEAR))
