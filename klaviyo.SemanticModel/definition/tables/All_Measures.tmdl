	measure ccnfPYUnqOpRt =
			
			VAR CurrentDates =
			    VALUES ( CampaignDimDate[Send Date] )
			
			VAR PYDates =
			    SELECTCOLUMNS (
			        CurrentDates,
			        "Send Date",
			        DATE (
			            YEAR ( [Send Date] ) - 1,
			            MONTH ( [Send Date] ),
			            DAY ( [Send Date] )
			        )
			    )
			RETURN
			CALCULATE (
			    [CCNF OpenRate],
			    TREATAS ( PYDates, CampaignDimDate[Send Date] )
			)
			// CALCULATE([CCNF OpenRate],DATEADD(CampaignDimDate[Send Date],-1,YEAR))
		displayFolder: CCNF Unique Opens
		lineageTag: aeef4354-bccb-4858-a669-ccf38dc6b1ee

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ccnfColor PM UNQOPRT' =
			
