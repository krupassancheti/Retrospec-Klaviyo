			RETURN
			    ROUND(Change * 100, 1) & "% (" &
			        IF(
			            Growth < 0,
			            ROUND(Growth * 100, 1) & "% " & down_arrow,
			            ROUND(Growth * 100, 1) & "% " & up_arrow
			        )
			    & ")"
			
			```
