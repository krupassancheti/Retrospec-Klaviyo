	measure 'ccnfYOY Revenue Change' = ```
			
			
			
			VAR up_arrow   = UNICHAR(129137)
			VAR down_arrow = UNICHAR(129139)
			
			VAR CurrentRevenue = [CCNF Revenue]
			VAR PYRevenue      = [ccnfPYTotalRevenue]
			
			VAR Change = CurrentRevenue - PYRevenue
			VAR Growth = DIVIDE(Change, PYRevenue)
			
