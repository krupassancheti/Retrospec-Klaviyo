	measure 'ccnfMOM Recipients Growth%' = ```
			
			VAR up_arrow = UNICHAR(129137) 
			VAR down_arrow = UNICHAR(129139) 
			VAR CurrentRecipients = [CCNF Recp] 
			VAR PPRecipients = [ccnfPPRecipients]
			VAR Growth = DIVIDE(CurrentRecipients-PPRecipients,PPRecipients)
			RETURN 
			    IF(
			        Growth<0, ROUND(Growth*100,1)&"% "& down_arrow,
			        ROUND(Growth*100,1)&"% "& up_arrow
			    )
			```
		displayFolder: CCNF Recip
		lineageTag: 8b456723-c592-4f6b-8698-d664972659c9

	measure ccnfPPRecipients = CALCULATE([CCNF Recp],DATESBETWEEN(CampaignDimDate[Send Date],[campaignstartofpreviousperiod],[campaignendofpreviousperiod]))
		formatString: 0
