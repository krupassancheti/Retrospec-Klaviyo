	measure cPPRecipients = CALCULATE([cRECIPIENTS],DATESBETWEEN(CampaignDimDate[Send Date],[campaignstartofpreviousperiod],[campaignendofpreviousperiod]))
		formatString: 0
		displayFolder: CRECP
		lineageTag: ad4ab1c0-4322-4b1f-bc53-0025928429fe

	measure cPYRecipients =
			
			VAR CurrentDates =
			    VALUES ( CampaignDimDate[Send Date] )
			
			VAR PYDates =
			    SELECTCOLUMNS (
			        CurrentDates,
			        "Send Date",
			        DATE (
			            YEAR ( [Send Date] ) - 1,
			            MONTH ( [Send Date] ),
			            DAY ( [Send Date] )
			        )
			    )
			RETURN
			CALCULATE (
			    [cRECIPIENTS],
			    TREATAS ( PYDates, CampaignDimDate[Send Date] )
			)
			// CALCULATE([cRECIPIENTS],DATEADD(CampaignDimDate[Send Date],-1,YEAR))
		formatString: 0
		displayFolder: CRECP
		lineageTag: 9757fdf8-4b5b-4982-8d57-9a51ba98dc52

	measure 'cMOM Recipients Growth%' = ```
			
			VAR up_arrow = UNICHAR(129137) 
			VAR down_arrow = UNICHAR(129139) 
			VAR CurrentRecipients = [cRECIPIENTS] 
			VAR PPRecipients = [cPPRecipients]
			VAR Growth = DIVIDE(CurrentRecipients-PPRecipients,PPRecipients)
			RETURN 
			    IF(
			        Growth<0, ROUND(Growth*100,1)&"% "& down_arrow,
			        ROUND(Growth*100,1)&"% "& up_arrow
			    )
			```
		displayFolder: CRECP
		lineageTag: 3d3bb0a7-0aac-4b3e-9ca9-7ec310d1acfd

	measure 'cYoY Recipients Growth%' = ```
			
			VAR up_arrow = UNICHAR(129137) 
			VAR down_arrow = UNICHAR(129139) 
			VAR CurrentRecipients = [cRECIPIENTS] 
			VAR PYRecipients = [cPYRecipients]
			VAR Growth = DIVIDE(CurrentRecipients-PYRecipients,PYRecipients)
			RETURN 
			    IF(
			        Growth<0, ROUND(Growth*100,1)&"% "& down_arrow,
			        ROUND(Growth*100,1)&"% "& up_arrow
			    )
			```
		displayFolder: CRECP
		lineageTag: a1743b8d-c3af-40fa-af5b-56166cc505be

	measure 'cColor PM Recipients' =
			
			VAR mom_growth = DIVIDE([cRECIPIENTS] - [cPPRecipients],[cPPRecipients])
			RETURN
			    IF(mom_growth<0, "red","green")
		displayFolder: CRECP
		lineageTag: 8f9f7508-2c79-4103-8ed7-82638a3a873f

