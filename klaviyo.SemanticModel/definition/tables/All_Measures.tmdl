	measure 'CCNF OpenRate' = ```
			
			SWITCH(
			    SELECTEDVALUE(Source[Source]),
			    "Campaigns", DIVIDE([cUNIQUE OPENS], [cRECIPIENTS]),
			    "Flows",     DIVIDE([FlowUnqOpens], [FlowRecip]),
			    DIVIDE(
			        [cUNIQUE OPENS] + [FlowUnqOpens],
			        [cRECIPIENTS] + [FlowRecip]
			    )
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: CCNF Measures
		lineageTag: 01f8e935-a051-4d8d-b157-bb70f02d5b1f

	measure 'ccnfMOM OpRt Growth%' = ```
			
			VAR up_arrow = UNICHAR(129137) 
			VAR down_arrow = UNICHAR(129139) 
			VAR CurrentOpens = [CCNF OpenRate]
			VAR PPUNQOP= [ccnfPPUnqOpRt]
			VAR Growth = DIVIDE(CurrentOpens-PPUNQOP,PPUNQOP)
			RETURN 
			    IF(
			        Growth<0, ROUND(Growth*100,1)&"% "& down_arrow,
			        ROUND(Growth*100,1)&"% "& up_arrow
			    )
			```
		displayFolder: CCNF Unique Opens
		lineageTag: f0d68123-6690-46d3-875a-3524e3917920

