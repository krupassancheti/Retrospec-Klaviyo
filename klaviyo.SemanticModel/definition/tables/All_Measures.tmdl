			FORMAT(Change, "$#,##0") &
			" (" &
			IF(
			    Growth < 0,
			    FORMAT(Growth, "0.0%") & " " & down_arrow,
			    FORMAT(Growth, "0.0%") & " " & up_arrow
			)
			& ")"
			
