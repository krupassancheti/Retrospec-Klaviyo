			VAR down_arrow = UNICHAR(129139) 
			VAR current_Revenue = [cSG_Revenue]
			VAR PY_Revenue = [cPYSG Revenue]
			VAR Growth = DIVIDE(current_Revenue - PY_Revenue,PY_Revenue)
			RETURN 
			    IF(
			        Growth<0, ROUND(Growth*100,1)&"% "& down_arrow,
			        ROUND(Growth*100,1)&"% "& up_arrow
			    )
			```
		displayFolder: Segment Data
		lineageTag: 2b7a6912-3b8b-4666-bc9c-101dafe8c197

