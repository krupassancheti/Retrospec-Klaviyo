	measure Revenue28DaysAgo = ```
			
			    CALCULATE(
			        SUM(daily[Revenue]),
			        FILTER(
			            ALL(dailytDynamicDates),
			            dailytDynamicDates[Date] = MAX(dailytDynamicDates[Date]) - 28
			        )
			    )
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 28daysbeforedata
		lineageTag: 6306c2c3-45bc-4af4-a1f4-d0a0b7315275

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

