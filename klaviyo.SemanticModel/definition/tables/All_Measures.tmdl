		lineageTag: dbc3b739-71ca-4eb3-a137-da647ed0d5f0

	measure ccnfPYRecipients =
			
			VAR CurrentDates =
			    VALUES ( CampaignDimDate[Send Date] )
			
			VAR PYDates =
			    SELECTCOLUMNS (
			        CurrentDates,
			        "Send Date",
			        DATE (
			            YEAR ( [Send Date] ) - 1,
			            MONTH ( [Send Date] ),
			            DAY ( [Send Date] )
			        )
			    )
			RETURN
			CALCULATE (
			    [CCNF Recp],
			    TREATAS ( PYDates, CampaignDimDate[Send Date] )
			)
			// CALCULATE([CCNF Recp],DATEADD(CampaignDimDate[Send Date],-1,YEAR))
		formatString: #,0
		displayFolder: CCNF Recip
		lineageTag: a6953da5-08c9-42c2-8cab-e684bf392323

