	partition campaign = m
		mode: import
		source =
				let
				    Source = AzureStorage.Blobs("retrospecblob"),
				    gold1 = Source{[Name="gold"]}[Data],
				
				    FileContent =
				        gold1{
				            [
				                #"Folder Path" = "https://retrospecblob.blob.core.windows.net/gold/",
				                Name = "klaviyo_data/campaign_selenium/campaign.csv"
				            ]
				        }[Content],
				
				    ImportedCSV =
				        Csv.Document(
				            FileContent,
				            [
				                Delimiter = ",",
				                Columns = 22,
				                Encoding = 65001,
				                QuoteStyle = QuoteStyle.None
				            ]
				        ),
				
				    PromotedHeaders =
				        Table.PromoteHeaders(
				            ImportedCSV,
				            [PromoteAllScalars = true]
				        ),
				
				    RemovedColumns =
				        Table.RemoveColumns(
				            PromotedHeaders,
				            {"Date"}
				        ),
				
				    RenamedColumns =
				        Table.RenameColumns(
				            RemovedColumns,
				            {
				                {"Total Clicks", "Clicked Email count"},
				                {"Unique Clicks", "Clicked Email unique"},
				                {"Total Opens", "Opened Email count"},
				                {"Unique Opens", "Opened Email unique"},
				                {"Total Placed Order", "Placed Order count"},
				                {"Total Placed Order Value", "Placed Order sum_value"},
				                {"Total Recipients", "Received Email unique"},
				                {"Bounces", "Bounced Email count"}
				            }
				        ),
				
				    // Change NON-date column types only
				    ChangedType =
				        Table.TransformColumnTypes(
				            RenamedColumns,
				            {
				                {"Campaign ID", type text},
				                {"Bounced Email count", Int64.Type},
				                {"Clicked Email count", Int64.Type},
				                {"Clicked Email unique", Int64.Type},
				                {"Opened Email count", Int64.Type},
				                {"Opened Email unique", Int64.Type},
				                {"Placed Order count", Int64.Type},
				                {"Placed Order sum_value", type number},
				                {"Received Email unique", Int64.Type},
				                {"Unique Unsubscribes", Int64.Type},
				                {"Total Unsubscribes", Int64.Type}
				            }
				        ),
				
				    RenamedRevenue =
				        Table.RenameColumns(
				            ChangedType,
				            {{"Placed Order sum_value", "Revenue"}}
				        ),
				
				    RevenueType =
				        Table.TransformColumnTypes(
				            RenamedRevenue,
				            {{"Revenue", Currency.Type}}
				        ),
				
				    // ✅ SAFE Send Date parsing (handles yyyy-mm-dd & dd-mm-yyyy)
				    FixedSendDate =
				        Table.TransformColumns(
				            RevenueType,
				            {
				                {
				                    "Send Date",
				                    each
				                        let
				                            txt = Text.Trim(Text.From(_))
				                        in
				                            if Text.Length(txt) = 10 and Text.Middle(txt, 4, 1) = "-"
				                            then
				                                Date.FromText(txt, "en-US")   // yyyy-mm-dd
				                            else
				                                Date.FromText(txt, "en-GB"), // dd-mm-yyyy
				                    type date
				                }
				            }
				        )
				in
				    FixedSendDate

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

