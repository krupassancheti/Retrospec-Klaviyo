table campaign
	lineageTag: 3abe5204-1a6d-41e0-9a74-2e84c3b145ac

	measure 'Campaign Order 4 Week Average' =
			CALCULATE(
			AVERAGEX(
			VALUES(CampaignDimDate[End of week]),
			[cCONVERSIONS]
			),
			FILTER(
			ALL(CampaignDimDate),
			CampaignDimDate[End of week] >= MAX(CampaignDimDate[End of week])-4 &&
			CampaignDimDate[End of week] <= MAX(CampaignDimDate[End of week])
			)
			)
		lineageTag: ade872b4-5955-4bf4-86a7-4b548a078baa

		annotation PBI_FormatHint = {"isGeneralNumber":true}

